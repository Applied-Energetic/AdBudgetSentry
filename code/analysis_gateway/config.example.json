{
  "default_provider": "deepseek",
  "deepseek": {
    "base_url": "https://api.deepseek.com",
    "api_key": "replace-with-your-api-key",
    "model": "deepseek-chat"
  },
  "local": {
    "base_url": "http://127.0.0.1:11434/v1",
    "api_key": "EMPTY",
    "model": "qwen2.5:3b-instruct"
  },
